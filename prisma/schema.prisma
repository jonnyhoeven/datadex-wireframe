generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model dataset {
    id             Int      @id @default(autoincrement())
    location_id    Int
    rin_score      Int
    theme          String
    source         String
    classification String
    user_scope     String?  // Field to scope data per user
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    @@index([user_scope])
}

model metadata {
    id                Int      @id @default(autoincrement())
    name              String
    title             String
    type              String
    description       String
    unit              String?
    information_url   String?
    calc_rules_url    String?
    refresh_frequency String?
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
}

model metadata_keywords

model keywords {
    id      Int
    name    String
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
}


