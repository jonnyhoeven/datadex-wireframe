# CKAN Project Configuration Template

# Site URL (required)
CKAN_SITE_URL=http://localhost:5000

# PostgreSQL password for databases
POSTGRES_PASSWORD=ckan_password

# Beaker session secret (required)
CKAN_BEAKER_SESSION_SECRET=secret_string_change_me

# Database URLs (constructed in docker-compose, but can be overridden here)
# CKAN_SQLALCHEMY_URL=postgresql://ckan_default:ckan_password@db/ckan_default
# CKAN_DATASTORE_WRITE_URL=postgresql://ckan_default:ckan_password@db/datastore_default
# CKAN_DATASTORE_READ_URL=postgresql://datastore_ro:ckan_password@db/datastore_default

# Solr URL
# CKAN_SOLR_URL=http://solr:8983/solr/ckan

# Redis URL
# CKAN_REDIS_URL=redis://redis:6379/1
